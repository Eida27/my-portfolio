# Public site URL used for metadata, sitemap, robots, and social previews.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Resend API key for contact form email delivery.
RESEND_API_KEY="re_your_resend_api_key"

# Inbox that receives portfolio contact form submissions.
CONTACT_TO_EMAIL="you@example.com"

# Verified sender address in Resend.
# For local testing before domain verification, Resend may allow onboarding@resend.dev.
CONTACT_FROM_EMAIL="Joshua Sumanghid <hello@example.com>"
